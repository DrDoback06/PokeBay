# Optional, strongly recommended on hosted deployments.
# Get a free key from https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# Future enhanced mode. The MVP runs without these.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production
POKEBAY_PORT=3000

# Static fallback exchange rates used for card price conversion when no UK price exists.
POKEBAY_USD_TO_GBP=0.78
POKEBAY_EUR_TO_GBP=0.86
