{
  "name": "pokebay",
  "version": "0.1.0",
  "private": true,
  "description": "UK-first Pokémon card and sealed product deal finder for eBay.",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node --check src/server.js && node --check src/lib/*.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pokemon",
    "ebay",
    "deals",
    "tcg",
    "cards"
  ],
  "license": "MIT"
}
